# Скопируйте в .env и заполните значения.
# Токен от @BotFather
BOT_TOKEN=

# ID супергруппы поддержки (форум), например -1001234567890
SUPPORT_GROUP_ID=

# Супер-администраторы (Telegram user id через запятую). Могут добавлять других админов.
# Узнать свой id: @userinfobot или написать боту /myid после запуска
SUPER_ADMIN_USER_IDS=

# Папка для SQLite и логов. Локально: ./data. В docker-compose переопределяется на /app/data.
DATA_DIR=./data
